{
  "name": "yapi2code",
  "displayName": "YAPI to Code",
  "description": "从 YAPI 接口自动生成 TypeScript 类型定义和 request 函数",
  "version": "0.0.1",
  "publisher": "yapi2code",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yapi2code-container",
          "title": "YAPI to Code",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "yapi2code-container": [
        {
          "type": "webview",
          "id": "yapi2code.view",
          "name": "YAPI to Code"
        }
      ]
    },
    "commands": [
      {
        "command": "yapi2code.refresh",
        "title": "YAPI: 刷新数据"
      },
      {
        "command": "yapi2code.logout",
        "title": "YAPI: 退出登录"
      },
      {
        "command": "yapi2code.editConfig",
        "title": "YAPI: 编辑 ytt.json"
      }
    ],
    "configuration": {
      "title": "YAPI to Code",
      "properties": {
        "yapi2code.outputPath": {
          "type": "string",
          "default": "src/api",
          "description": "生成的接口文件输出目录"
        },
        "yapi2code.importStatement": {
          "type": "string",
          "default": "import request from '@/utils/request';",
          "description": "自定义 request 导入语句"
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "vite build --config vite.config.ext.ts",
    "build:webview": "vite build --config vite.config.webview.ts",
    "dev:webview": "vite --config vite.config.webview.ts",
    "watch:ext": "vite build --config vite.config.ext.ts --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "less": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
